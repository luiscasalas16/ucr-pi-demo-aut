@page "/empleados"
@attribute [StreamRendering]
@* Exige que el usuario esté autenticado para poder acceder al componente o página Razor. *@
@attribute [Authorize]

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Identity.Web
@using System.Net.Http.Headers
@using System.Net.Http.Json

@* Permite obtener el estado de autenticación actual del usuario dentro de componentes Razor. *@
@inject AuthenticationStateProvider AuthenticationStateProvider
@* Servicio utilizado para adquirir access tokens desde Microsoft Entra en nombre del usuario autenticado. *@
@inject ITokenAcquisition TokenAcquisition
@* Factory utilizada para crear instancias configuradas de HttpClient. *@
@inject IHttpClientFactory HttpClientFactory
@* Permite acceder a la configuración de la aplicación desde el componente. *@
@inject IConfiguration Configuration
@* Servicio utilizado para manejar automáticamente desafíos de autenticación,
   consentimiento incremental y recuperación de tokens cuando Microsoft Entra lo requiere. *@
@inject MicrosoftIdentityConsentAndConditionalAccessHandler ConsentHandler

<PageTitle>Empleados</PageTitle>

<h1>Empleados</h1>

@if (_empleados == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Cédula</th>
                <th>Nombre</th>
                <th>Apellidos</th>
                <th>Correo</th>
                <th>Salario</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var forecast in _empleados)
            {
                <tr>
                    <td>@forecast.Cedula</td>
                    <td>@forecast.Nombre</td>
                    <td>@forecast.Apellidos</td>
                    <td>@forecast.Correo</td>
                    <td>@forecast.Salario</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Empleado[]? _empleados;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Obtiene el estado de autenticación actual del usuario.
            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        
            // Obtiene el ClaimsPrincipal asociado al usuario autenticado.
            var user = authenticationState.User;

            // Verifica que el usuario esté autenticado antes de intentar solicitar un access token.
            if (user.Identity?.IsAuthenticated != true)
                return;

            // Obtiene los scopes configurados para consumir el API protegido.
            var scopes = Configuration
                .GetSection("DownstreamApi:Scopes")
                .Get<string[]>()!;
                
            // Solicita un access token a Microsoft Entra para consumir el API en nombre del usuario autenticado.
            var accessToken = await TokenAcquisition.GetAccessTokenForUserAsync(
                  scopes,
                  user: user
              );

            // Obtiene una instancia configurada de HttpClient para consumir DemoAutApi.
            var httpClient = HttpClientFactory.CreateClient("DemoAutApi");

            // Envía el access token como Bearer Token en el encabezado Authorization de las solicitudes HTTP.
            httpClient.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", accessToken);

            // Consume el endpoint protegido del API utilizando el access token obtenido previamente.
            _empleados = (await httpClient.GetFromJsonAsync<List<Empleado>>("read/GetEmpleados"))?.ToArray();
        }
        catch (MicrosoftIdentityWebChallengeUserException ex)
        {
            // Maneja automáticamente la excepción lanzada por Microsoft Entra,
            // redirigiendo al usuario para recuperar o volver a solicitar el access token requerido.
            ConsentHandler.HandleException(ex);
        }
    }
}
